# Restart rems cleanly
#
# 
# The only thing I can see that happens when you login is that a record goes
# into the users table, so we just insert this directly in the database.
# So before you do this, get a record into keycloak (by registering
# with your preferred password) and then reset the REMS database.
# The record will remain in keycloak, ready to be taken over with this
# user record.

: ${REMS_NS:?}
: ${KUBECONFIG:?}
: ${REMS_API_KEY:?}

echo "Creating admin user..."
rems_db_k8s <<EOF
insert into users values ('admin','{"name": "Admin User", "email": "rems_admin@aucklanduni.ac.nz"}');
EOF
echo

echo "Granting admin the owner role and add api key ..."
rems_shell_k8s <<EOF
java -Drems.config=config/config.edn -jar rems.jar grant-role owner admin
java -Drems.config=config/config.edn -jar rems.jar api-key add $REMS_API_KEY
EOF
echo

echo "Restarting..."
rems_restart_k8s
